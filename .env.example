# ローカル開発
#   wrangler login
#   npm run dev
#
# 管理者パネル（専用ログイン画面 + セッション Cookie）
#   ADMIN_BASIC_USER=admin
#   ADMIN_BASIC_PASSWORD=（本番は Cloudflare Pages シークレットに登録）
#   ログイン URL: /admin/login.html
#
# OAuth（.dev.vars に設定、リポジトリにはコミットしない）
#   ログイン用（ScienceHUB-OAuth など）
#   GOOGLE_CLIENT_ID=
#   GOOGLE_CLIENT_SECRET=
#   MICROSOFT_CLIENT_ID=
#   MICROSOFT_CLIENT_SECRET=
#   MICROSOFT_TENANT_ID=common
#   OAUTH_REDIRECT_BASE=http://localhost:8788
#
# Google カレンダー連携（スケジュール同期）
#   詳細: docs/google-calendar-integration.md
#   カレンダー用 OAuth クライアント（scienceHUBcalendar など・ログイン用とは別）
#   GOOGLE_CALENDAR_CLIENT_ID=
#   GOOGLE_CALENDAR_CLIENT_SECRET=
#   GOOGLE_CALENDAR_REFRESH_TOKEN=  # calendar スコープ付きリフレッシュトークン
#   GOOGLE_CALENDAR_ALL_GROUPS_ID=  # 「自然科学部」カレンダーの ID
#   各グループ: hub_groups.google_calendar_id にグループ名のカレンダー ID を設定
#
# 3D印刷 Google Calendar（Service Account・スケジュール用 GCal とは別）
#   GOOGLE_3DPRINT_CALENDAR_ID=
#   GOOGLE_3DPRINT_SERVICE_ACCOUNT_EMAIL=
#   GOOGLE_3DPRINT_PRIVATE_KEY=
#
# 3D印刷 Discord 通知（Pages Functions + sciencehub-worker 共用）
#   DISCORD_WEBHOOK_URL=
#
# R2 直アップロード / 直ダウンロード（presigned URL）
#   Cloudflare ダッシュボード → R2 → Manage R2 API Tokens で発行
#   バケット sciencehub-files への Object Read & Write 権限が必要
#   ブラウザから R2 へ直接 PUT/GET するため、バケット CORS も設定すること
#   （AllowedMethods: GET, PUT, HEAD / ExposeHeaders: ETag）
#   R2_ACCESS_KEY_ID=
#   R2_SECRET_ACCESS_KEY=
#   R2_ACCOUNT_ID=          # Cloudflare アカウント ID
#   R2_BUCKET_NAME=sciencehub-files
#
# Office Online プレビュー（Word / Excel / PowerPoint）
#   Microsoft のサーバーがファイル URL を取得して表示します
#   - 本番は HTTPS の公開 URL が必要（localhost では不可）
#   - R2 presigned 未設定時は署名付きトークン URL（/api/storage/preview/office-file）を使用
#   - 推奨: 10 MB 以下のファイル
#
# 本番（Cloudflare Pages → 設定 → 変数とシークレット）
#   上記と同じキーをシークレットとして登録
#   OAUTH_REDIRECT_BASE は省略可（リクエストの Origin を使用）
#   リダイレクト URI（Google / Microsoft コンソール）:
#     https://s.mmh-virtual.jp/api/auth/oauth/google/callback
#     https://s.mmh-virtual.jp/api/auth/oauth/microsoft/callback
#
# 手動デプロイ（リモート D1 マイグレーション → ビルド → Pages デプロイ）
#   npm run deploy
#
# GitHub Actions（main への push でも同じ npm run deploy を実行）
# リポジトリ Secrets に以下を登録:
#   CLOUDFLARE_API_TOKEN  — Account.Cloudflare Pages:Edit, D1:Edit 権限
#   CLOUDFLARE_ACCOUNT_ID — Cloudflare アカウント ID
#
# 初回セットアップ
#   npm run db:create
#   npm run r2:create
#   wrangler.jsonc の database_id を確認
