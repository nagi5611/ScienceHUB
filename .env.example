# ローカル開発
#   wrangler login
#   npm run dev
#
# 管理者パネル（専用ログイン画面 + セッション Cookie）
#   ADMIN_BASIC_USER=admin
#   ADMIN_BASIC_PASSWORD=（本番は Cloudflare Pages シークレットに登録）
#   ログイン URL: /admin/login.html
#
# OAuth（.dev.vars に設定、リポジトリにはコミットしない）
#   GOOGLE_CLIENT_ID=
#   GOOGLE_CLIENT_SECRET=
#   MICROSOFT_CLIENT_ID=
#   MICROSOFT_CLIENT_SECRET=
#   MICROSOFT_TENANT_ID=common
#   OAUTH_REDIRECT_BASE=http://localhost:8788
#
# Google カレンダー連携（スケジュール同期）
#   詳細: docs/google-calendar-integration.md
#   GOOGLE_CALENDAR_REFRESH_TOKEN=  # calendar スコープ付きリフレッシュトークン
#   GOOGLE_CALENDAR_ALL_GROUPS_ID=  # 「自然科学部」カレンダーの ID
#   各グループ: hub_groups.google_calendar_id にグループ名のカレンダー ID を設定
#
# 本番（Cloudflare Pages → 設定 → 変数とシークレット）
#   上記と同じキーをシークレットとして登録
#   OAUTH_REDIRECT_BASE は省略可（リクエストの Origin を使用）
#   リダイレクト URI（Google / Microsoft コンソール）:
#     https://s.mmh-virtual.jp/api/auth/oauth/google/callback
#     https://s.mmh-virtual.jp/api/auth/oauth/microsoft/callback
#
# 手動デプロイ（リモート D1 マイグレーション → ビルド → Pages デプロイ）
#   npm run deploy
#
# GitHub Actions（main への push でも同じ npm run deploy を実行）
# リポジトリ Secrets に以下を登録:
#   CLOUDFLARE_API_TOKEN  — Account.Cloudflare Pages:Edit, D1:Edit 権限
#   CLOUDFLARE_ACCOUNT_ID — Cloudflare アカウント ID
#
# 初回セットアップ
#   npm run db:create
#   npm run r2:create
#   wrangler.jsonc の database_id を確認
